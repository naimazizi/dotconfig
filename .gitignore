!claude/settings.json
!claude/README.md
!pi/settings.json
!mcp/mcp.json

# Folder to not ignore
!/amethyst/
!/atuin/
!/claude/
!/fish/
!/foot/
!/ghostty/
!/gitui/
!/helix/
!/hypr/
!/kitty/
