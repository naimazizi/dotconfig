{
  "mcpServers": {
    "bigquery": {
      "type": "local",
      "command": "uvx",
      "args": [
        "mcp-server-bigquery",
        "--project",
        "{env:BIGQUERY_PROJECT}",
        "--location",
        "{env:BIGQUERY_LOCATION}"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "sequential-thinking": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "jupyter": {
      "type": "local",
      "command": "uvx",
      "args": ["jupyter-mcp-server"],
      "env": {
        "JUPYTER_URL": "{env:JUPYTER_URL}",
        "JUPYTER_TOKEN": "{env:JUPYTER_TOKEN}",
        "ALLOW_IMG_OUTPUT": "true"
      },
      "enabled": true
    }
  }
}
