{
  "effortLevel": "medium",
  "enabledPlugins": {
    "claude-coat@claude-coat": true,
    "plannotator@plannotator": true,
    "ponytail@ponytail": true,
    "pyrefly-lsp@pyrefly-lsp-claude-plugin": true
  },
  "extraKnownMarketplaces": {
    "claude-coat": {
      "source": {
        "repo": "efebolukbasi/claude-coat",
        "source": "github"
      }
    },
    "plannotator": {
      "source": {
        "repo": "backnotprop/plannotator",
        "source": "github"
      }
    },
    "ponytail": {
      "source": {
        "repo": "dietrichgebert/ponytail",
        "source": "github"
      }
    },
    "pyrefly-lsp-claude-plugin": {
      "source": {
        "repo": "lolpack/pyrefly-lsp-claude-plugin",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook read-dedup",
            "type": "command"
          }
        ],
        "matcher": "Read"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook rewrite",
            "type": "command"
          }
        ],
        "matcher": "Bash|bash"
      },
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook redirect",
            "type": "command"
          }
        ],
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory|Glob|glob"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/opt/homebrew/bin/lean-ctx hook observe",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  },
  "theme": "custom:claude-coat:kanagawa-wave"
}
