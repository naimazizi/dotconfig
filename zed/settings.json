{
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "model": "anthropic/claude-sonnet-4-6"
      },
      "favorite_config_option_values": {
        "model": ["anthropic/claude-sonnet-4-6", "litellm_tvlk/claude-sonnet-4.6"]
      },
      "type": "registry"
    }
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Kanagawa Wave"
  },

  "lsp": {
    "pyrefly": {
      "binary": {
        "path": "~/.local/share/nvim/mason/bin/pyrefly",
        "arguments": ["lsp"]
      }
    }
  },
  "languages": {
    "Python": {
      "language_servers": ["pyrefly", "ruff", "!basedpyright"],
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "git_panel": {
    "dock": "right"
  },
  "icon_theme": "Catppuccin Mocha",
  "base_keymap": "VSCode",
  "ui_font_size": 17,
  "buffer_font_size": 12,
  "file_finder": {
    "modal_max_width": "medium"
  },
  "buffer_font_family": "Monaspace Krypton NF",
  "vim_mode": true,
  "vim": {},
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show": true
  },
  "scrollbar": {
    "show": "auto"
  },
  "tabs": {
    "show_diagnostics": "errors"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15
  },
  "agent": {
    "default_model": {
      "effort": "low",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    }
  },

  "inlay_hints": {
    "enabled": true
  },
  "terminal": {
    "font_family": "Monaspace Krypton NF",
    "env": {
      "EDITOR": "zed --wait"
    }
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules"
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "project_panel": {
    "button": true,
    "dock": "right",
    "git_status": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "which_key": {
    "enabled": true
  }
}
