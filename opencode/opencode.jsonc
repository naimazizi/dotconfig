{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "litellm_tvlk/claude-sonnet-4-6",
  "plugin": [
    "@dietrichgebert/ponytail",
    "cc-safety-net",
    "envsitter-guard@latest",
    "@tarquinen/opencode-dcp@latest",
    "@plannotator/opencode@latest",
    "opencode-claude-auth@latest",
  ],
  "provider": {
    "litellm_tvlk": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM TVLK",
      "options": {
        "baseURL": "{env:LITELLM_API_ENDPOINT}",
      },
      "models": {
        "claude-opus-4.7": {
          "name": "claude-opus-4.7",
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
        },
        "claude-sonnet-4.6": {
          "name": "claude-sonnet-4.6",
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
        },
        "claude-haiku-4.5": {
          "name": "claude-haiku-4.5",
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
        },
      },
    },
  },
  "mcp": {
    "bigquery": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-bigquery",
        "--project",
        "{env:BIGQUERY_PROJECT}",
        "--location",
        "{env:BIGQUERY_LOCATION}",
      ],
      "enabled": true,
      "timeout": 30000,
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "jupyter": {
      "type": "local",
      "command": ["uvx", "jupyter-mcp-server@latest"],
      "env": {
        "JUPYTER_URL": "{env:JUPYTER_URL}",
        "JUPYTER_TOKEN": "{env:JUPYTER_TOKEN}",
        "ALLOW_IMG_OUTPUT": "true",
      },
      "enabled": true,
    },
  },
}
